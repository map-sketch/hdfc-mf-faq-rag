# .streamlit/secrets.toml.example
# Copy this file to .streamlit/secrets.toml for local dev,
# OR paste these values into Streamlit Cloud → App Settings → Secrets.

GROQ_API_KEY = "gsk_your_groq_api_key_here"
HF_TOKEN = ""                          # Optional — leave blank if not needed

CHROMA_PERSIST_DIR = "./vectorstore"
COLLECTION_NAME = "hdfc_mutual_fund_corpus"
BGE_MODEL_NAME = "BAAI/bge-small-en-v1.5"
GROQ_MODEL_NAME = "llama-3.3-70b-versatile"
RETRIEVAL_TOP_K = "5"
RETRIEVAL_SCORE_THRESHOLD = "0.2"
